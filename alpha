function getOperationEntry(name) {
    const key = String(name || '').trim();
    if (!key) return null;

    const entry = APP.operationCacheMemory?.[key];
    return entry ? cloneData(entry) : null;
}

  function setOperationEntry(name, value) {
    const key = String(name || '').trim();
    if (!key) return Promise.resolve();

    APP.operationCacheMemory[key] = cloneData(value);

    return queueOperationCacheWrite(async () => {
        await idbPutOperation(key, APP.operationCacheMemory[key]);
    });
}

function updateOperationEntry(name, patch) {
    const existing = getOperationEntry(name) || {};
    const merged = { ...existing, ...patch, updatedAt: Date.now() };
    return setOperationEntry(name, merged);
}

function deleteOperationEntry(name) {
    const key = String(name || '').trim();
    if (!key) return Promise.resolve();

    delete APP.operationCacheMemory[key];

    return queueOperationCacheWrite(async () => {
        await idbDeleteOperation(key);
    });
}

