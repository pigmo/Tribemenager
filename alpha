    function validatePostSequence(postsData) {
      const config = getConfig();
        const issues = [];
        let prevFinal = null;
        let prevPost = null;

        for (const post of postsData) {
            if (post.skipped) continue;
            if (!post.validFormat) continue;

            if (prevFinal === null) {
                prevFinal = post.finalValue;
                prevPost = post;
                continue;
            }

            const expected = prevFinal + post.increment;

            if (expected !== post.finalValue) {
                let hint = '';
                let recovered = false;

                if (config.verification.useRecovery && String(expected).endsWith(String(post.finalValue))) {
    hint = ` Możliwy ucięty początek liczby: wpisano ${post.finalValue}, możliwe że miało być ${expected}.`;
    recovered = true;
} else if (Math.abs(expected - post.finalValue) < 10) {
                    hint = ' Możliwa literówka o 1 cyfrę.';
                }

                issues.push({
                    type: 'sequence_mismatch',
                    postIndex: post.index,
                    nick: post.nick,
                    prevPostIndex: prevPost ? prevPost.index : null,
                    previousFinal: prevFinal,
                    increment: post.increment,
                    expectedFinal: expected,
                    actualFinal: post.finalValue,
                    recovered,
                    message: `Post #${post.index} (${post.nick}) → poprzednio ${prevFinal}, wpisano +${post.increment}, powinno być ${expected}, a jest ${post.finalValue}.${hint}`
                });

                prevFinal = recovered ? expected : post.finalValue;
                prevPost = post;
                continue;
            }

            prevFinal = post.finalValue;
            prevPost = post;
        }

        return issues;
    }


