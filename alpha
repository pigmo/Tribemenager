      function parsePostData(text) {
        const raw = String(text || '').replace(/\u00a0/g, ' ');

        const config = getConfig();

if (config.verification.useSkip && raw.toLowerCase().includes('!skip')) {
            return {
                increment: null,
                finalValue: null,
                validFormat: false,
                skipped: true
            };
        }

