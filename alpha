  function getSingleIcon(mode, rank = 1) {
    if (mode === 'minimal') return '';
    if (mode === 'numbers') return `${rank}.`;

    if (mode === 'medals') {
        if (rank === 1) return '🥇';
        if (rank === 2) return '🥈';
        if (rank === 3) return '🥉';
        return '🏅';
    }

    if (mode === 'fire') return '🔥';
    if (mode === 'stars') return '⭐';
    if (mode === 'crowns') return rank <= 3 ? '👑' : '♕';
    if (mode === 'swords') return rank <= 3 ? '⚔️' : '🗡️';
    if (mode === 'skulls') return rank <= 3 ? '☠️' : '💀';
    if (mode === 'gems') return rank <= 3 ? '💎' : '♦️';
    if (mode === 'animals') {
        if (rank === 1) return '🐺';
        if (rank === 2) return '🦊';
        if (rank === 3) return '🐗';
        return '🐾';
    }

  if (mode === 'birds') {
    if (rank === 1) return '🦅';
    if (rank === 2) return '🦉';
    if (rank === 3) return '🐦';
    return '🪶';
}
    if (mode === 'shields') return rank <= 3 ? '🛡️' : '⛨';
    if (mode === 'flags') return rank <= 3 ? '🚩' : '🏳️';
    if (mode === 'bolts') {
    if (rank === 1) return '⚡⚡⚡';
    if (rank === 2) return '⚡⚡';
    if (rank === 3) return '⚡';
    return '✦';
}

    if (mode === 'skull') return '💀';
    if (mode === 'grave') return '🪦';
    if (mode === 'sleep') return '😴';
    if (mode === 'banned') return '🚫';
    if (mode === 'mailbox') return '📭';
  if (mode === 'redx') return '❌';
if (mode === 'zzz') return '💤';

    return '';
}


  function getTieredIcons(value, mode, highThreshold, mediumThreshold) {
    let baseIcon = '';

    if (mode === 'stars') baseIcon = '⭐';
    else if (mode === 'fire') baseIcon = '🔥';
    else if (mode === 'gems') baseIcon = '💎';
    else if (mode === 'swords') baseIcon = '⚔️';
    else if (mode === 'skulls') baseIcon = '☠️';
    else if (mode === 'shields') baseIcon = '🛡️';
    else if (mode === 'flags') baseIcon = '🚩';
    else if (mode === 'bolts') baseIcon = '⚡';
    else if (mode === 'numbers') return '';
    else if (mode === 'minimal') return '';

    if (!baseIcon) return '';

    if (value >= highThreshold) return baseIcon.repeat(3);
    if (value >= mediumThreshold) return baseIcon.repeat(2);
    return baseIcon;
}


    function buildTableHeader(columns) {
    const cells = [];

