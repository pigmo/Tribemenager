// CACHE OPERACJI / INDEXEDDB
// ==================================================
const OP_CACHE_KEY = 'tm_v7_operations_cache';
const OP_DB_NAME = 'tm_v7_verify_cache';
const OP_DB_VERSION = 1;
const OP_STORE_OPERATIONS = 'operations';

APP.operationCacheMemory = APP.operationCacheMemory || {};
APP.operationCacheReady = false;
APP.operationCacheBackend = 'indexeddb';
APP.operationCacheDb = null;
APP.operationCacheWriteChain = Promise.resolve();


  function cloneData(value) {
    if (value === null || value === undefined) return value;

    try {
        return structuredClone(value);
    } catch (_) {
        return JSON.parse(JSON.stringify(value));
    }
}

function parseLegacyOperationCache() {
    try {
        const raw = localStorage.getItem(OP_CACHE_KEY);
        if (!raw) return {};

        const parsed = JSON.parse(raw);
        return parsed && typeof parsed === 'object' ? parsed : {};
    } catch (err) {
        console.warn('[TM] parseLegacyOperationCache error:', err);
        return {};
    }
}

function getOperationUpdatedAt(entry) {
    return Number(entry?.updatedAt || 0);
}


  function mergeOperationCaches(baseCache, extraCache) {
    const out = { ...(baseCache || {}) };

    Object.entries(extraCache || {}).forEach(([key, value]) => {
        const current = out[key];

        if (!current || getOperationUpdatedAt(value) >= getOperationUpdatedAt(current)) {
            out[key] = value;
        }
    });

    return out;
}

  function idbRequestToPromise(request) {
    return new Promise((resolve, reject) => {
        request.onsuccess = () => resolve(request.result);
        request.onerror = () => reject(request.error || new Error('IndexedDB request failed'));
    });
}


  function openOperationCacheDb() {
    if (APP.operationCacheDb) {
        return Promise.resolve(APP.operationCacheDb);
    }

    return new Promise((resolve, reject) => {
        const request = indexedDB.open(OP_DB_NAME, OP_DB_VERSION);

        request.onupgradeneeded = () => {
            const db = request.result;

            if (!db.objectStoreNames.contains(OP_STORE_OPERATIONS)) {
                db.createObjectStore(OP_STORE_OPERATIONS, { keyPath: 'key' });
            }
        };

        request.onsuccess = () => {
            APP.operationCacheDb = request.result;
            resolve(APP.operationCacheDb);
        };

        request.onerror = () => reject(request.error || new Error('Nie udało się otworzyć IndexedDB'));
        request.onblocked = () => reject(new Error('IndexedDB jest zablokowane przez inną kartę/przeglądarkę'));
    });
}

  async function idbReadAllOperations() {
    const db = await openOperationCacheDb();

    return new Promise((resolve, reject) => {
        const tx = db.transaction(OP_STORE_OPERATIONS, 'readonly');
        const store = tx.objectStore(OP_STORE_OPERATIONS);
        const out = {};

        const request = store.openCursor();

        request.onsuccess = () => {
            const cursor = request.result;

            if (!cursor) {
                resolve(out);
                return;
            }

            const row = cursor.value || {};
            const key = String(row.key || '').trim();

            if (key) {
                out[key] = cloneData(row.value);
            }

            cursor.continue();
        };

        request.onerror = () => reject(request.error || new Error('Nie udało się odczytać operacji z IndexedDB'));
    });
}


  async function idbPutOperation(key, value) {
    const db = await openOperationCacheDb();
    const tx = db.transaction(OP_STORE_OPERATIONS, 'readwrite');
    const store = tx.objectStore(OP_STORE_OPERATIONS);

    await idbRequestToPromise(store.put({
        key,
        updatedAt: Date.now(),
        value: cloneData(value)
    }));

    await new Promise((resolve, reject) => {
        tx.oncomplete = () => resolve();
        tx.onerror = () => reject(tx.error || new Error('Nie udało się zapisać operacji do IndexedDB'));
        tx.onabort = () => reject(tx.error || new Error('Transakcja IndexedDB została przerwana'));
    });
}

  async function idbDeleteOperation(key) {
    const db = await openOperationCacheDb();
    const tx = db.transaction(OP_STORE_OPERATIONS, 'readwrite');
    const store = tx.objectStore(OP_STORE_OPERATIONS);

    await idbRequestToPromise(store.delete(key));

    await new Promise((resolve, reject) => {
        tx.oncomplete = () => resolve();
        tx.onerror = () => reject(tx.error || new Error('Nie udało się usunąć operacji z IndexedDB'));
        tx.onabort = () => reject(tx.error || new Error('Transakcja IndexedDB została przerwana'));
    });
}

  async function idbReplaceAllOperations(cache) {
    const db = await openOperationCacheDb();
    const tx = db.transaction(OP_STORE_OPERATIONS, 'readwrite');
    const store = tx.objectStore(OP_STORE_OPERATIONS);

    await idbRequestToPromise(store.clear());

    for (const [key, value] of Object.entries(cache || {})) {
        await idbRequestToPromise(store.put({
            key,
            updatedAt: Date.now(),
            value: cloneData(value)
        }));
    }

    await new Promise((resolve, reject) => {
        tx.oncomplete = () => resolve();
        tx.onerror = () => reject(tx.error || new Error('Nie udało się przepisać cache operacji do IndexedDB'));
        tx.onabort = () => reject(tx.error || new Error('Transakcja IndexedDB została przerwana'));
    });
}

  function persistOperationCacheFallbackLocalStorage() {
    localStorage.setItem(OP_CACHE_KEY, JSON.stringify(APP.operationCacheMemory || {}));
}

  function queueOperationCacheWrite(task) {
    APP.operationCacheWriteChain = APP.operationCacheWriteChain
        .then(async () => {
            if (APP.operationCacheBackend === 'indexeddb') {
                await task();
                return;
            }

            persistOperationCacheFallbackLocalStorage();
        })
        .catch(err => {
            console.error('[TM] Operation cache write error:', err);
        });

    return APP.operationCacheWriteChain;
}

  async function initializeOperationCache() {
    const legacyCache = parseLegacyOperationCache();

    if (typeof indexedDB === 'undefined') {
        APP.operationCacheBackend = 'localStorage';
        APP.operationCacheMemory = cloneData(legacyCache || {});
        APP.operationCacheReady = true;
        return APP.operationCacheMemory;
    }

    try {
        await openOperationCacheDb();

        let dbCache = await idbReadAllOperations();

        if (Object.keys(legacyCache).length) {
            dbCache = mergeOperationCaches(dbCache, legacyCache);
            await idbReplaceAllOperations(dbCache);
            localStorage.removeItem(OP_CACHE_KEY);
        }

        APP.operationCacheMemory = cloneData(dbCache || {});
        APP.operationCacheBackend = 'indexeddb';
        APP.operationCacheReady = true;
        return APP.operationCacheMemory;
    } catch (err) {
        console.error('[TM] initializeOperationCache fallback to localStorage:', err);
        APP.operationCacheBackend = 'localStorage';
        APP.operationCacheMemory = cloneData(legacyCache || {});
        APP.operationCacheReady = true;
        return APP.operationCacheMemory;
    }
}

  function loadOperationCache() {
    return cloneData(APP.operationCacheMemory || {});
}

function saveOperationCache(cache) {
    APP.operationCacheMemory = cloneData(cache || {});

    return queueOperationCacheWrite(async () => {
        await idbReplaceAllOperations(APP.operationCacheMemory || {});
