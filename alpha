  function buildDailyStats(postsData, rankingData) {
    const daysMap = {};

    for (const post of postsData) {
        if (post.skipped) continue;
        if (!post.validFormat) continue;
        if (post.increment === null) continue;
        if (!(post.date instanceof Date) || Number.isNaN(post.date.getTime())) continue;

        const dayKey = formatDateKey(post.date);

        if (!daysMap[dayKey]) {
            daysMap[dayKey] = {
                date: new Date(post.date.getFullYear(), post.date.getMonth(), post.date.getDate()),
                players: {},
                total: 0
            };
        }

        if (!daysMap[dayKey].players[post.nick]) {
            daysMap[dayKey].players[post.nick] = 0;
        }

        daysMap[dayKey].players[post.nick] += post.increment;
        daysMap[dayKey].total += post.increment;
    }

    const days = Object.values(daysMap)
        .sort((a, b) => a.date - b.date)
        .map(day => {
            const sorted = Object.entries(day.players).sort((a, b) => b[1] - a[1]);

            function pickBest(metric) {
                if (!sorted.length) return null;

                let best = null;

                for (const [nick, val] of sorted) {
                    const stats = rankingData[nick] || { points: 0, villages: 0 };

                    let metricValue = 0;
                    if (metric === 'fakeCount') {
                        metricValue = val;
                    } else if (metric === 'perVillage') {
                        metricValue = stats.villages ? val / stats.villages : 0;
                    } else if (metric === 'per1kPoints') {
                        metricValue = stats.points ? val / (stats.points / 1000) : 0;
                    }

                    if (!best || metricValue > best.metricValue) {
                        best = {
                            nick,
                            fakeCount: val,
                            metricValue,
                            points: stats.points || 0,
                            villages: stats.villages || 0
                        };
                    }
                }

                return best;
            }

            return {
                date: day.date,
                dateKey: formatDateKey(day.date),
                total: day.total,
                players: day.players,
                sorted,
                mvp: {
                    fakeCount: pickBest('fakeCount'),
                    perVillage: pickBest('perVillage'),
                    per1kPoints: pickBest('per1kPoints')
                }
            };
        });

    return days;
}

  function buildPeriodStats(postsData, total, rankingData) {
    const datedPosts = postsData
        .filter(post =>
            !post.skipped &&
            post.validFormat &&
            post.increment !== null &&
            post.date instanceof Date &&
            !Number.isNaN(post.date.getTime())
        )
        .sort((a, b) => a.date - b.date);

    const dailyStats = buildDailyStats(datedPosts, rankingData);

    const firstDate = datedPosts[0]?.date || null;
    const lastDate = datedPosts[datedPosts.length - 1]?.date || null;
    const daysCount = Math.max(dailyStats.length, 1);
    const averagePerDay = total / daysCount;

    return {
        firstDate,
        lastDate,
        daysCount,
        averagePerDay,
        dailyStats
    };
}

