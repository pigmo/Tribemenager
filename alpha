    try {
        const raw = localStorage.getItem(getTrustedPlayersStorageKey());
        if (!raw) return [];
        const parsed = JSON.parse(raw);
        return normalizePlayersArray(parsed);
    } catch (err) {
        Logger.warn(`Trusted players read error: ${err?.message || err}`);
        return [];
    }
}

function saveTrustedPlayers(players) {
    const normalized = normalizePlayersArray(players);
    localStorage.setItem(getTrustedPlayersStorageKey(), JSON.stringify(normalized));
    return normalized;
}

function isTrustedPlayer(player) {
    const nick = normalizeNick(player);
    if (!nick) return false;
    return getTrustedPlayers().includes(nick);
}

function setTrustedPlayer(player, trusted) {
    const nick = normalizeNick(player);
    if (!nick) return getTrustedPlayers();

    const set = new Set(getTrustedPlayers());

    if (trusted) {
        set.add(nick);
    } else {
        set.delete(nick);
    }

    return saveTrustedPlayers([...set]);
}

function toggleTrustedPlayer(player) {
    const nick = normalizeNick(player);
    if (!nick) return getTrustedPlayers();

    const trusted = isTrustedPlayer(nick);
    return setTrustedPlayer(nick, !trusted);
}

