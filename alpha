async function sendVerifySharingMessages() {
    const state = APP.state.verify || {};

    if (state.sharingSending) {
        alert('Wysyłka sharingowa już trwa.');
        return;
    }

    const { sharingMessagesByPlayer } = rebuildVerifySharingState();
    const recipients = [...sharingMessagesByPlayer.keys()].sort((a, b) => a.localeCompare(b, 'pl'));

    if (!recipients.length) {
        alert('Brak zaufanych odbiorców sharingowych.');
        return;
    }

    if (!confirm(`Wyślę ${recipients.length} spersonalizowanych wiadomości (1 gracz = 1 wiadomość). Kontynuować?`)) {
        return;
    }

    state.sharingSending = true;

    const sendBtn = document.getElementById('verifySharingSendAllBtn');
    if (sendBtn) sendBtn.disabled = true;

    appendVerifySharingLog('--- start wysyłki sharingowej ---', '#9f9');

    let okCount = 0;
    let failCount = 0;
    let partialCount = 0;

    try {
        for (let i = 0; i < recipients.length; i++) {
            const player = recipients[i];
            const draft = sharingMessagesByPlayer.get(player);

            if (!draft?.body) {
                failCount++;
                appendVerifySharingLog(`BŁĄD ${i + 1}/${recipients.length}: ${player} | brak treści wiadomości`, '#f88');
                continue;
            }

            appendVerifySharingLog(`Wysyłam ${i + 1}/${recipients.length}: ${player}`, '#9cf');

            try {
                const result = await sendTribalMail([player], draft.subject, draft.body);

                if (result.ok) {
                    okCount++;

                    if (result.partial) {
                        partialCount++;
                        appendVerifySharingLog(
                            `OK z ostrzeżeniem: ${player} | ${result.message || 'częściowy sukces'}`,
                            '#ffcc66'
                        );
                    } else {
                        appendVerifySharingLog(`OK: ${player}`, '#8f8');
                    }
                } else {
                    failCount++;
                    appendVerifySharingLog(
                        `BŁĄD: ${player} | ${result.message || `HTTP ${result.status}`}`,
                        '#f88'
                    );
                }
            } catch (err) {
                failCount++;
                appendVerifySharingLog(`BŁĄD: ${player} | ${err?.message || err}`, '#f88');
            }

            if (i < recipients.length - 1) {
                await new Promise(resolve => setTimeout(resolve, 900));
            }
        }

        appendVerifySharingLog(
            `KONIEC: OK=${okCount}, częściowe=${partialCount}, błędy=${failCount}`,
            failCount ? '#ffcc66' : '#8f8'
        );
    } finally {
        state.sharingSending = false;
        if (sendBtn) sendBtn.disabled = false;
    }
}




