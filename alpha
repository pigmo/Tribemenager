    let latest = null;

    for (const cmd of getAllPlannerCommands(planners)) {
        if (normalizeCoord(cmd?.target) !== coord) continue;

        const dueUntil = getCommandDueUntil(cmd);
        if (dueUntil && (!latest || dueUntil > latest)) {
