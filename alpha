  function deepMerge(base, extra) {
    if (!extra || typeof extra !== 'object') return structuredClone(base);

    const out = Array.isArray(base) ? [...base] : { ...base };

    for (const [k, v] of Object.entries(extra)) {
        if (
            v &&
            typeof v === 'object' &&
            !Array.isArray(v) &&
            base &&
            typeof base[k] === 'object' &&
            !Array.isArray(base[k])
        ) {
            out[k] = deepMerge(base[k], v);
        } else {
            out[k] = v;
        }
    }

    return out;
}

  const Storage = {
    read() {
        try {
            return deepMerge(
                DEFAULTS,
                JSON.parse(localStorage.getItem(APP.storageKey) || '{}')
            );
        } catch {
            return structuredClone(DEFAULTS);
        }
    },

    write(data) {
        localStorage.setItem(APP.storageKey, JSON.stringify(data));
    },

    get(path, fallback = null) {
        const data = this.read();
        const value = path.split('.').reduce((acc, part) => {
            return acc && Object.prototype.hasOwnProperty.call(acc, part)
                ? acc[part]
                : undefined;
        }, data);

        return value === undefined ? fallback : value;
    },

    set(path, value) {
        const data = this.read();
        const parts = path.split('.');
        let ref = data;

        while (parts.length > 1) {
            const part = parts.shift();
            if (!ref[part] || typeof ref[part] !== 'object') {
                ref[part] = {};
            }
            ref = ref[part];
        }

        ref[parts[0]] = value;
        this.write(data);
    },
};

