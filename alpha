async function runVerifyFromCache() {
    const state = APP.state.verify;

    if (state.running) {
        alert('Weryfikacja już trwa.');
        return;
    }

    const subject = document.getElementById('verifySubject')?.value.trim() || '';
    if (!subject) {
        alert('Wpisz temat operacji.');
        return;
    }

    const cache = getOperationEntry(subject);
    if (!cache) {
        alert('Brak cache dla tej operacji.');
        return;
    }

    setVerifyTaskState({
        status: 'running',
        startedAt: Date.now()
    });

    Logger.clear();
    state.running = true;

    try {
        Logger.info(`START sprawdzania z cache: ${subject}`);

        state.summaryMap = arrayToMap(cache.summaryEntries);
        state.targets = cache.targets || [];
        state.messageByPlayer = arrayToMap(cache.messageEntries);
        state.plannerByPlayer = arrayToMap(cache.plannerEntries);
        state.sharingByPlayer = arrayToMap(cache.sharingEntries);
        state.meta = cache.meta || null;
        state.sharingBaseByPlayer = new Map();
        state.sharingMessagesByPlayer = new Map();

        state.timing = cache.timing ? {
            ...cache.timing,
            latest: cache.timing.latest ? new Date(cache.timing.latest) : null,
            recommended: cache.timing.recommended ? new Date(cache.timing.recommended) : null,
        } : null;

        renderTiming(state.timing);

        const targetAnalysis = await analyzeTargetsFinal(
            subject,
            state.targets,
            state.plannerByPlayer,
            state.timing,
            (done, total, targetCoord) => {
                const meta = getVerifyProgressMeta(state);

                setVerifyProgress(
                    `Cele ${done}/${total}`,
                    1 + meta.playersList.length + done,
                    meta.totalProgressSteps,
                    targetCoord
                );
            }
        );

      state.analysis = targetAnalysis;

const { playerAnalysis, verifyAlerts } = renderVerifyDerivedResults(state, targetAnalysis);

        if (APP.debug?.verboseVerify) {
            console.log('playerAnalysis (cache) =', playerAnalysis);
            console.log('verifyAlerts (cache) =', verifyAlerts);
        }

        Logger.info(`Verify alerts z cache: late=${verifyAlerts.late.length}, none=${verifyAlerts.noneSent.length}`);

        {
            const meta = getVerifyProgressMeta(state);
            setVerifyProgress('Gotowe', meta.totalProgressSteps, meta.totalProgressSteps, 'KONIEC');
        }

        renderVerifyCacheInfo();

        Logger.info('KONIEC sprawdzania z cache');
        window.__tmVerifyState = state;
    } catch (err) {
        const errorMessage = String(err?.message || err || 'Unknown error');

        setVerifyTaskState({
            status: 'error',
            error: errorMessage
        });

        setVerifyProgress(
            'Błąd',
            APP.state.verify?.progress?.current || 0,
            APP.state.verify?.progress?.total || 1,
            errorMessage
        );

        Logger.error(`FATAL cache: ${errorMessage}`);
        console.error(err);
        alert(`Błąd cache: ${errorMessage}`);
    } finally {
        state.running = false;

        if (getVerifyTaskState()?.status === 'running') {
            setVerifyTaskState({
                status: 'idle',
                finishedAt: Date.now()
            });
        }
    }
}

async function runVerifyFlow() {
    const state = APP.state.verify;

    if (state.running) {
        alert('Weryfikacja już trwa.');
        return;
    }

    const subject = document.getElementById('verifySubject')?.value.trim() || '';
    const summaryText = document.getElementById('verifySummaryText')?.value || '';
    const plannerLinksText = document.getElementById('verifyPlannerLinksText')?.value || '';
    const bufferMinutes = Number(document.getElementById('verifyBufferMinutes')?.value || 5);
    if (!subject) {
        alert('Wpisz temat operacji.');
        return;
    }

    if (!summaryText.trim()) {
        alert('Wklej Podsumowanie rozpiski.');
        return;
    }

    if (!plannerLinksText.trim()) {
        alert('Wklej linki plannerów.');
        return;
    }

    setVerifyTaskState({
        status: 'running',
        startedAt: Date.now()
    });

    await saveVerifyDraft(subject, {
        summaryText,
        plannerLinksText
    });

    Storage.set('verify.timingBufferMinutes', bufferMinutes);

    Logger.clear();

    state.running = true;
    state.summaryMap = new Map();
    state.messageByPlayer = new Map();
    state.plannerByPlayer = new Map();
    state.commandsByPlayer = new Map();
    state.analysis = null;
    state.timing = null;
    state.targets = [];
    state.sharingByPlayer = new Map();
    state.sharingBaseByPlayer = new Map();
    state.sharingMessagesByPlayer = new Map();
    state.meta = null;
    state.playerIdByNick = new Map();

    try {
        Logger.info('START weryfikacji rozpiski');

        const parsed = parseSummary(summaryText);
        const summaryMap = parsed.players;
        const targets = parsed.targets;
        const operationMeta = parseOperationMeta(summaryText);
        const playersList = [...summaryMap.keys()];

        state.meta = operationMeta;
        state.summaryMap = summaryMap;
        state.targets = targets;

        Logger.info(`Gracze z podsumowania: ${summaryMap.size}`);
        Logger.info(`Cele z podsumowania: ${targets.length}`);

        if (!summaryMap.size || !targets.length) {
            throw new Error('Parser podsumowania nie wykrył graczy albo celów.');
        }

        {
            const progressMeta = getVerifyProgressMeta(state);
            setVerifyProgress('Statusy sharingu', 0, progressMeta.totalProgressSteps, 'start');
        }

        const sharingMap = await fetchCommandSharingStatus();
        state.sharingByPlayer = sharingMap;
        state.playerIdByNick = new Map(
            [...sharingMap.entries()].map(([nick, row]) => [nick, row.playerId])
        );

        Logger.info(`Wczytano statusy sharingu: ${sharingMap.size}`);

        const plannerLinksMap = parsePlannerLinksMap(plannerLinksText);

        if (!plannerLinksMap.size) {
            throw new Error('Brak linków plannerów. Wklej listę [b]Nick[/b] + [url]link[/url].');
        }

        Logger.info(`Wczytano linki plannerów: ${plannerLinksMap.size}`);

        for (let playerIndex = 0; playerIndex < playersList.length; playerIndex++) {
            const player = playersList[playerIndex];

            {
                const progressMeta = getVerifyProgressMeta(state);
                setVerifyProgress(
                    `Planery ${playerIndex + 1}/${progressMeta.playersList.length}`,
                    1 + playerIndex,
                    progressMeta.totalProgressSteps,
                    player
                );
            }

            const playerKey = normalizeNickKey(player);
            const plannerEntry = plannerLinksMap.get(playerKey);
            const plannerUrl = plannerEntry?.url || '';

            if (!plannerUrl) {
                Logger.warn(`${player}: brak linku planera na liście`);
                state.messageByPlayer.set(player, {
                    player,
                    plannerUrl: '',
                    source: 'manual-links',
                    status: 'NO_LINK'
                });
                state.plannerByPlayer.set(player, {
                    player,
                    plannerUrl: '',
                    commands: [],
                    status: 'NO_LINK'
                });
                continue;
            }

            state.messageByPlayer.set(player, {
                player,
                plannerUrl,
                source: 'manual-links',
                status: 'LINK_OK'
            });

            try {
                const cachedPlanner = getCachedPlannerEntry(subject, player);

                if (
                    cachedPlanner &&
                    cachedPlanner.plannerUrl === plannerUrl &&
                    Array.isArray(cachedPlanner.commands) &&
                    cachedPlanner.commands.length
                ) {
                    state.plannerByPlayer.set(player, cachedPlanner);
                    Logger.info(`${player}: plan z cache (${cachedPlanner.commands.length} komend)`);
                    continue;
                }

                const planner = await fetchPlanner(player, plannerUrl);

                const plannerRow = {
                    ...planner,
                    status: planner.parseMeta?.warnings?.length ? 'PARSED_WITH_WARNINGS' : 'OK'
                };

                state.plannerByPlayer.set(player, plannerRow);
                await updateCachedPlannerEntry(subject, player, sanitizePlannerEntryForCache(plannerRow));

                const strategy = planner.parseMeta?.strategy || 'unknown';
                Logger.info(
                    `${player}: plan pobrany (${planner.commands.length} komend, parser=${strategy}, api=${planner.parseMeta?.apiStatus || 'BRAK'}, apiCmd=${planner.parseMeta?.apiCommandsCount ?? 0})`
                );

                logPlannerApiProbeOnce(player, planner);
            } catch (err) {
                Logger.error(`${player}: błąd planera: ${err.message}`);
                state.plannerByPlayer.set(player, {
                    player,
                    plannerUrl,
                    commands: [],
                    status: 'PARSE_ERROR',
                    error: err.message
                });
            }
        }

        state.timing = getOperationTiming(state.plannerByPlayer, bufferMinutes);

        {
            const progressMeta = getVerifyProgressMeta(state);
            setVerifyProgress(
                `Planery ${progressMeta.playersList.length}/${progressMeta.playersList.length}`,
                1 + progressMeta.playersList.length,
                progressMeta.totalProgressSteps,
                'gotowe'
            );
        }

        renderTiming(state.timing);

        const targetAnalysis = await analyzeTargetsFinal(
            subject,
            state.targets,
            state.plannerByPlayer,
            state.timing,
            (done, total, targetCoord) => {
                const progressMeta = getVerifyProgressMeta(state);
                setVerifyProgress(
                    `Cele ${done}/${total}`,
                    1 + progressMeta.playersList.length + done,
                    progressMeta.totalProgressSteps,
                    targetCoord
                );
            }
        );

        state.analysis = targetAnalysis;

        const { playerAnalysis, verifyAlerts } = renderVerifyDerivedResults(state, targetAnalysis);

        if (APP.debug?.verboseVerify) {
            console.log('playerAnalysis =', playerAnalysis);
            console.log('verifyAlerts =', verifyAlerts);
        }

        Logger.info(`Verify alerts: late=${verifyAlerts.late.length}, none=${verifyAlerts.noneSent.length}`);

        {
            const progressMeta = getVerifyProgressMeta(state);
            setVerifyProgress('Gotowe', progressMeta.totalProgressSteps, progressMeta.totalProgressSteps, 'KONIEC');
        }

        await updateOperationEntry(subject, {
            meta: operationMeta,
            timing: state.timing,
            summaryEntries: mapToArray(state.summaryMap),
            messageEntries: mapToArray(state.messageByPlayer),
            plannerEntries: [...state.plannerByPlayer.entries()].map(([key, value]) => [
                key,
                sanitizePlannerEntryForCache(value)
            ]),
            sharingEntries: mapToArray(state.sharingByPlayer),
            targets: state.targets,
            plannerLinksText,
            savedAt: new Date().toISOString(),
        });

        renderVerifyCacheInfo();
        Logger.info(`Zapisano cache operacji: ${subject}`);
        Logger.info('KONIEC weryfikacji');

        window.__tmVerifyState = state;
    } catch (err) {
        const errorMessage = String(err?.message || err || 'Unknown error');

        setVerifyTaskState({
            status: 'error',
            error: errorMessage
        });

        setVerifyProgress(
            'Błąd',
            APP.state.verify?.progress?.current || 0,
            APP.state.verify?.progress?.total || 1,
            errorMessage
        );

        Logger.error(`FATAL: ${errorMessage}`);
        console.error(err);
        alert(`Błąd: ${errorMessage}`);
    } finally {
        state.running = false;

        if (getVerifyTaskState()?.status === 'running') {
            setVerifyTaskState({
                status: 'idle',
                finishedAt: Date.now()
            });
        }
    }
}

  function buildVerifyPlayerStats(analysis) {
    const result = [];

    if (!analysis || !analysis.players) return result;

    Object.entries(analysis.players).forEach(([nick, p]) => {
        const total = p.total || 0;
        const sent = p.sent || 0;
        const late = p.late || 0;
        const missing = p.missing || 0;

        const percent = total ? (sent / total) * 100 : 0;

        result.push({
            nick,
            total,
            sent,
            late,
            missing,
            percent
        });
    });

    result.sort((a, b) => b.percent - a.percent);

    return result;
}




