    function commandMatchesPlan(realCmd, planCmd) {
        if (!realCmd || !planCmd) return false;
        if (normalizeCoord(realCmd.from) !== normalizeCoord(planCmd.from)) return false;
        if (normalizeCoord(realCmd.target) !== normalizeCoord(planCmd.target)) return false;
        return true;
    }

    function buildMatchedSet(plans, commandsByPlayer) {
        const used = new Set();
        const matched = new Set();
        for (const [player, plan] of plans.entries()) {
            const real = commandsByPlayer.get(player)?.commands || [];
            for (const cmd of (plan.commands || [])) {
                const key = `${player}__${cmd.from}__${cmd.target}__${cmd.sendDate}__${cmd.sendTo}`;
                const idx = real.findIndex((r, i) => !used.has(`${player}__${i}`) && commandMatchesPlan(r, cmd));
                if (idx >= 0) {
                    used.add(`${player}__${idx}`);
                    matched.add(key);
                }
            }
        }
        return matched;
    }

    function getPlanStatus(cmd, matched, now) {
        const from = toDate(cmd.sendDate, cmd.sendFrom);
        const to = toDate(cmd.sendDate, cmd.sendTo);
        if (matched) return 'sent';
        if (now < from) return 'pending';
        if (now >= from && now <= to) return 'window';
        if (now > to) return 'late';
        return 'unknown';
    }

    function analyze(plans, summaryMap, commandsByPlayer, sharingByPlayer) {
        const now = new Date();
        const matchedSet = buildMatchedSet(plans, commandsByPlayer);
        const rows = [];
        let stats = {
            totalPlanned: 0,
            totalShouldByNow: 0,
            totalSent: 0,
            totalLate: 0,
            totalPending: 0,
            totalWindow: 0,
            playersNeedAction: 0,
        };

        for (const [player, plan] of plans.entries()) {
            const summary = summaryMap.get(player) || { off: 0, snob: 0, fake: 0, total: 0 };
            const sharing = sharingByPlayer.get(player) || null;
            const cmdInfo = commandsByPlayer.get(player) || { commands: [], blocked: false };
            const row = {
                player,
                expectedTotal: summary.total || 0,
                expectedOff: summary.off || 0,
                expectedSnob: summary.snob || 0,
                expectedFake: summary.fake || 0,
                plannedTotal: (plan.commands || []).length,
                shouldByNow: 0,
                sent: 0,
                late: 0,
                pending: 0,
                window: 0,
                missingNow: 0,
                sharing: sharing ? (sharing.canView === true ? 'OK' : sharing.canView === false ? 'BRAK' : '?') : '?',
                sharingTitle: sharing?.title || '',
                playerId: sharing?.playerId || '',
                commandCountSeen: cmdInfo.commands?.length || 0,
                blocked: !!cmdInfo.blocked,
            };

            for (const cmd of (plan.commands || [])) {
                const key = `${player}__${cmd.from}__${cmd.target}__${cmd.sendDate}__${cmd.sendTo}`;
                const status = getPlanStatus(cmd, matchedSet.has(key), now);
                stats.totalPlanned++;
                if (status === 'sent') row.sent++;
                if (status === 'pending') row.pending++;
                if (status === 'window') row.window++;
                if (status === 'late') row.late++;
                if (status === 'window' || status === 'late' || status === 'sent') row.shouldByNow++;
            }

            row.missingNow = Math.max(0, row.shouldByNow - row.sent);
            if (row.missingNow > 0 || row.blocked) stats.playersNeedAction++;
            stats.totalShouldByNow += row.shouldByNow;
            stats.totalSent += row.sent;
            stats.totalLate += row.late;
            stats.totalPending += row.pending;
            stats.totalWindow += row.window;
            rows.push(row);
        }

        rows.sort((a, b) => b.missingNow - a.missingNow || b.late - a.late || a.player.localeCompare(b.player, 'pl'));
        return { stats, rows };
    }

