function renderPlayerAnalysis(rows) {
    const host = document.getElementById('verifyTableBox');
    if (!host) return;

    const compactMode = isCompactMode();
    const safeRows = Array.isArray(rows) ? rows : [];

    const normalized = safeRows.map(r => {
        const expected = Number(r?.expected || 0);
        const planned = Number(r?.planned || 0);
        const sent = Number(r?.sent || r?.found || 0);
        const diff = Number.isFinite(r?.diff) ? Number(r.diff) : (sent - expected);

        const percent = expected > 0
            ? Math.max(0, Math.min(100, (sent / expected) * 100))
            : (sent > 0 ? 100 : 0);

        let status = 'POPRAWNE';
        if (sent <= 0 && expected > 0) status = 'BRAK';
        else if (sent < expected) status = 'CZĘŚCIOWO';
        else if (sent > expected) status = 'NADMIAR';

        return {
            ...r,
            expected,
            planned,
            sent,
            diff,
            percent,
            status
        };
    });

    const correctCount = normalized.filter(r => r.status === 'POPRAWNE').length;
    const partialCount = normalized.filter(r => r.status === 'CZĘŚCIOWO').length;
    const zeroCount = normalized.filter(r => r.status === 'BRAK').length;

    const sorted = [...normalized].sort((a, b) => {
        if (a.percent !== b.percent) return b.percent - a.percent;
        return a.player.localeCompare(b.player, 'pl');
    });

    if (compactMode) {
        host.innerHTML = `
            <div style="margin-top:12px; display:grid; gap:10px;">
