  // ==================================================
// REQUEST QUEUE / FETCH
// ==================================================
class RequestQueue {
    constructor() {
        this.running = false;
        this.items = [];
        this.multiplier = 1;
    }

    status() {
        return {
            size: this.items.length,
            running: this.running,
            multiplier: this.multiplier,
        };
    }

    renderStatus() {
        const el = document.getElementById('tmQueueStatus');
        if (!el) return;

        const s = this.status();
        el.textContent = `Kolejka: ${s.size} | x${s.multiplier.toFixed(2)}${s.running ? ' | praca' : ''}`;
    }

    async delay(ms) {
        return new Promise(resolve => setTimeout(resolve, ms));
    }

    async push(task, meta = {}) {
        return new Promise((resolve, reject) => {
            this.items.push({ task, meta, resolve, reject });
            this.renderStatus();

            if (!this.running) {
                this.run();
            }
        });
    }

    async run() {
        if (this.running) return;

        this.running = true;
        this.renderStatus();

        while (this.items.length) {
            const item = this.items.shift();
            this.renderStatus();

            const baseDelay = item.meta.delay ?? Storage.get('request.delay', 1600);
            const jitter = Storage.get('request.jitter', 350);
            const totalDelay = Math.round(baseDelay * this.multiplier + Math.random() * jitter);

            try {
                Logger.info(`Kolejka -> ${item.meta.title || 'request'} (${totalDelay} ms)`);
                await this.delay(totalDelay);

                const result = await item.task();

                this.multiplier = Math.max(1, this.multiplier * 0.95);
                item.resolve(result);
            } catch (err) {
                const message = String(err?.message || err || 'Unknown error');

                if (/429/.test(message)) {
                    this.multiplier = Math.min(5, this.multiplier * Storage.get('request.retry429Multiplier', 2));
                    Logger.warn(`429 wykryte. Zwolnienie kolejki do x${this.multiplier.toFixed(2)}`);
                }

                item.reject(err);
            }
        }

        this.running = false;
        this.renderStatus();
    }
}

function createAbsoluteGameUrl(url) {
    return new URL(url, location.origin).toString();
}

async function sameOriginFetchText(url, init = {}, title = url, delay = null) {
    return APP.queue.push(async () => {
        const res = await fetch(createAbsoluteGameUrl(url), {
            credentials: 'same-origin',
            ...init,
        });

        const text = await res.text();

        if (!res.ok) {
            throw new Error(`HTTP ${res.status} dla ${url}`);
        }

        return text;
    }, { title, delay });
}

async function crossFetchText(url, title = url) {
    const plannerDelay = Storage.get('request.plannerDelay', 1800);

    return APP.queue.push(() => new Promise((resolve, reject) => {
        if (typeof GM_xmlhttpRequest !== 'function') {
            reject(new Error('GM_xmlhttpRequest niedostępny - sprawdź @grant GM_xmlhttpRequest oraz @connect plemiona-planer.pl'));
            return;
        }

        GM_xmlhttpRequest({
            method: 'GET',
            url,
            onload: (resp) => {
                if (resp.status >= 200 && resp.status < 400) {
                    resolve(resp.responseText);
                } else {
                    reject(new Error(`HTTP ${resp.status} dla ${url}`));
                }
            },
            onerror: () => {
                reject(new Error(`Błąd żądania GM_xmlhttpRequest dla ${url}`));
            }
        });
    }), { title, delay: plannerDelay });
}

function parseHtml(html) {
    return new DOMParser().parseFromString(html, 'text/html');
}

function normalizeNick(text) {
    return String(text || '')
        .replace(/\u00A0/g, ' ')
        .replace(/\s+/g, ' ')
        .trim();
}

function normalizeNickKey(text) {
    return normalizeNick(text).toLowerCase();
}

function normalizeCoord(text) {
    const m = String(text || '').match(/(\d{1,3})\|(\d{1,3})/);
    return m ? `${m[1]}|${m[2]}` : '';
}

function decodeHtml(text) {
    const ta = document.createElement('textarea');
    ta.innerHTML = String(text || '');
    return ta.value;
}

function stripBb(text) {
    return decodeHtml(String(text || ''))
        .replace(/\[url=([^\]]+)\]([\s\S]*?)\[\/url\]/gi, '$2')
        .replace(/\[url\]([\s\S]*?)\[\/url\]/gi, '$1')
        .replace(/\[\/?(?:b|i|u|quote|code|size|color|font|center|left|right|img|spoiler|table|tr|td|th|list|\*)[^\]]*\]/gi, '')
        .replace(/&gt;/gi, '>')
        .replace(/&#10;/g, '\n')
        .replace(/\r/g, '')
        .replace(/[ \t]+\n/g, '\n')
        .replace(/\n{3,}/g, '\n\n')
        .trim();
}

function extractCoords(text) {
    return [...String(text || '').matchAll(/(\d{3}\|\d{3})/g)].map(m => m[1]);
}

function extractTime(text) {
    const m = String(text || '').match(/\b(\d{2}:\d{2}:\d{2})\b/);
    return m ? m[1] : '';
}

function extractDate(text) {
    const m = String(text || '').match(/\b(\d{4}-\d{2}-\d{2})\b/);
    return m ? m[1] : '';
}

function extractTargetIdFromUrl(url) {
    const m = String(url || '').match(/[?&]target=(\d+)/i);
    return m ? m[1] : '';
}


