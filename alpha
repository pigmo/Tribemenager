function getOperationTiming(plans, bufferMinutes) {
    const commands = getAllPlannerCommands(plans);

    if (!commands.length) return null;

    let latestSend = null;
    let firstArrival = null;
    let staleAfter = null;

    commands.forEach(cmd => {
        const sendEnd = getCommandSendEnd(cmd);
        const arrivalStart = getCommandArrivalStart(cmd);
        const dueUntil = getCommandDueUntil(cmd);

        if (sendEnd && (!latestSend || sendEnd > latestSend)) {
            latestSend = sendEnd;
        }

        if (arrivalStart && (!firstArrival || arrivalStart < firstArrival)) {
            firstArrival = arrivalStart;
        }

        if (dueUntil && (!staleAfter || dueUntil > staleAfter)) {
            staleAfter = dueUntil;
        }
    });

    const now = new Date();

    let recommended = null;
    if (latestSend && firstArrival) {
        recommended = new Date(
            Math.max(
                latestSend.getTime() + bufferMinutes * 60 * 1000,
                firstArrival.getTime() - bufferMinutes * 60 * 1000
            )
        );
    } else if (firstArrival) {
        recommended = new Date(firstArrival.getTime() - bufferMinutes * 60 * 1000);
    } else if (latestSend) {
        recommended = new Date(latestSend.getTime() + bufferMinutes * 60 * 1000);
    }

    let status = 'BRAK DANYCH';
    if (recommended && now < recommended) {
        status = 'ZA WCZEŚNIE';
    } else if (recommended && firstArrival && now >= recommended && now < firstArrival) {
        status = 'MOŻNA SPRAWDZAĆ';
    } else if (firstArrival && staleAfter && now >= firstArrival && now <= staleAfter) {
        status = 'TRWA OKNO WERYFIKACJI';
    } else if (staleAfter && now > staleAfter) {
        status = 'PO CZASIE / NIEWIARYGODNE';
    }

    return {
        latest: latestSend,          // alias pod starsze miejsca
        latestSend,
        firstArrival,
        recommended,
        staleAfter,
        status
    };
}

