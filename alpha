                        tooMany: 0,
                        matchedOrders: [],
                        missingOrders: plannedOrders
                    });
                    continue;
                }

                const incomingForPlayer = attackRows.filter(cmd =>
                    cmd.player === a.player
                );

                const matched = matchPlannedOrdersToIncoming(plannedOrders, incomingForPlayer);

                row.players.push({
                    player: a.player,
                    expected: plannedOrders.length || a.count,
                    found: matched.matchedCount,
                    missing: matched.missingCount,
                    tooMany: Math.max(0, matched.unusedIncoming.length),
                    matchedOrders: matched.matches,
                    missingOrders: matched.missing
                });
            }

            await updateCachedTargetIncoming(subject, t.target, sanitizeTargetRowForCache(row));
            Logger.info(`Cel ${t.target}: incoming pobrany`);

            result.push(row);

            if (typeof onProgress === 'function') {
                onProgress(result.length, targets.length, t.target);
            }
        } catch (err) {
            Logger.warn(`Cel ${t.target}: ${err.message}`);
            result.push({
                target: t.target,
                targetMeta: {
                    coord: t.target,
                    villageName: '',
                    villageHref: '',
                    ownerName: '',
                    ownerHref: ''
                },
                error: err.message,
                stale: false,
                players: t.assignments.map(a => ({
                    player: a.player,
                    expected: a.count,
                    found: 0,
                    missing: a.count,
                    tooMany: 0,
                    matchedOrders: [],
                    missingOrders: []
                }))
            });
          if (typeof onProgress === 'function') {
    onProgress(result.length, targets.length, t.target);
}
        }
    }

    return result;
}

  function countPlannerCommands(commands) {
    const out = {
        off: 0,
        snob: 0,
        fake: 0,
        total: 0
    };

    for (const cmd of (commands || [])) {
        if (cmd.type === 'off') out.off++;
        else if (cmd.type === 'snob') out.snob++;
        else if (cmd.type === 'fake') out.fake++;

        out.total++;
    }

    return out;
}

function analyzePlayers(summaryMap, plannerMap, targetAnalysis) {
    const rows = [];

    const foundByPlayer = new Map();

    for (const targetRow of (targetAnalysis || [])) {
        for (const p of (targetRow.players || [])) {
            const name = p.player || p.nick || '';
            if (!name) continue;

            const prev = foundByPlayer.get(name) || {
                found: 0,
                expectedOnTargets: 0,
                missingOnTargets: 0
            };

            prev.found += Number(p.found || 0);
            prev.expectedOnTargets += Number(p.expected || 0);
            prev.missingOnTargets += Number(p.missing || 0);

            foundByPlayer.set(name, prev);
        }
    }

    for (const [player, summary] of summaryMap.entries()) {
        const plan = plannerMap.get(player);
        const counts = countPlannerCommands(plan?.commands || []);
        const incomingStats = foundByPlayer.get(player) || {
            found: 0,
            expectedOnTargets: 0,
            missingOnTargets: 0
        };

        const sent = Number(incomingStats.found || 0);
        const expected = Number(summary.total || 0);
        const planned = Number(counts.total || 0);

        const percent = expected > 0 ? (sent / expected) * 100 : 0;

        const row = {
            player,

            expected,
            expectedOff: summary.off || 0,
            expectedSnob: summary.snob || 0,
            expectedFake: summary.fake || 0,

            planned,
            plannedOff: counts.off,
            plannedSnob: counts.snob,
            plannedFake: counts.fake,

            sent,
            found: sent,
            missing: Math.max(0, expected - sent),
            expectedOnTargets: incomingStats.expectedOnTargets,
            missingOnTargets: incomingStats.missingOnTargets,

            percent,
            diff: sent - expected
        };

        rows.push(row);
    }

    rows.sort((a, b) =>
        Math.abs(b.diff) - Math.abs(a.diff) ||
        a.player.localeCompare(b.player, 'pl')
    );

    return rows;
}

function enrichWithTiming(rows, plannerByPlayer) {
    const now = Date.now();
    const safeRows = Array.isArray(rows) ? rows : [];

    return safeRows.map(r => {
        const playerName = r.player || r.nick || '';

        const plannerEntry =
            plannerByPlayer?.get?.(playerName) ||
            plannerByPlayer?.[playerName] ||
            null;

        const orders = Array.isArray(plannerEntry?.commands)
            ? plannerEntry.commands
            : [];

        let shouldBeSent = 0;

        orders.forEach(order => {
            const deadline = getCommandWindowEnd(order);
            if (!deadline) return;

            if (deadline.getTime() <= now) {
                shouldBeSent++;
            }
        });

        const sent = Number(r.sent || 0);

        let timingStatus = 'ON_TIME';
        if (shouldBeSent > sent) {
            timingStatus = sent === 0 ? 'NONE_SENT' : 'LATE';
        }

        return {
            ...r,
            shouldBeSent,
            timingStatus
        };
    });
}

function buildVerifyAlerts(rows) {
    const safeRows = Array.isArray(rows) ? rows : [];

    const noneSent = safeRows
        .filter(r => r.timingStatus === 'NONE_SENT')
        .sort((a, b) => {
            const aName = a.player || a.nick || '';
            const bName = b.player || b.nick || '';
            return aName.localeCompare(bName, 'pl');
        });

    const late = safeRows
        .filter(r => r.timingStatus === 'LATE')
        .sort((a, b) => {
            const aMiss = (a.shouldBeSent || 0) - (a.planned || 0);
            const bMiss = (b.shouldBeSent || 0) - (b.planned || 0);

            if (aMiss !== bMiss) return bMiss - aMiss;

            const aName = a.player || a.nick || '';
            const bName = b.player || b.nick || '';
            return aName.localeCompare(bName, 'pl');
        });

    return {
        noneSent,
        late
    };
}

  function buildVerifyDerivedResults(state, targetAnalysis) {
    const summaryMap = state?.summaryMap || new Map();
    const plannerByPlayer = state?.plannerByPlayer || new Map();
    const analysis = Array.isArray(targetAnalysis) ? targetAnalysis : [];

    let playerAnalysis = analyzePlayers(
        summaryMap,
        plannerByPlayer,
        analysis
    );

    playerAnalysis = enrichWithTiming(playerAnalysis, plannerByPlayer);

    const verifyAlerts = buildVerifyAlerts(playerAnalysis);

    return {
        targetAnalysis: analysis,
        playerAnalysis,
        verifyAlerts
    };
}

function renderVerifyDerivedResults(state, targetAnalysis) {
    const derived = buildVerifyDerivedResults(state, targetAnalysis);

    renderTargets(derived.targetAnalysis);
    renderVerifyAlerts(derived.verifyAlerts);
    renderPlayerAnalysis(derived.playerAnalysis);
    renderTrustedPlayersBox();
    renderVerifySharingBox();

    return derived;
}


