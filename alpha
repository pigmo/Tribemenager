  function parsePlannerOutline(outlineText) {
    const text = decodeHtml(String(outlineText || '').replace(/\r/g, ''));
    const lines = text.split('\n').map(x => x.trim()).filter(Boolean);
    const commands = [];

    for (let i = 0; i < lines.length; i++) {
        const headMatch = lines[i].match(/^(\d+)\.\s+(.*)$/);
        if (!headMatch) continue;

        const index = Number(headMatch[1]);
        const label = stripBb(headMatch[2]);

        const blockLines = [lines[i]];
        let j = i + 1;

        while (j < lines.length && !/^\d+\.\s+/.test(lines[j])) {
            blockLines.push(lines[j]);
            j++;
        }

        i = j - 1;


              const rawBlock = blockLines.join('\n');
        const plainBlock = stripBb(rawBlock);
        const allCoords = extractCoords(plainBlock);

        let from = '';
        let target = '';

        if (allCoords.length >= 2) {
            from = normalizeCoord(allCoords[0]);
            target = normalizeCoord(allCoords[1]);
        }

        const dateMatch = plainBlock.match(/\b(\d{4}-\d{2}-\d{2})\b/);
        const timeRangeMatch = plainBlock.match(/\b(\d{2}:\d{2}:\d{2})\s*-\s*(\d{2}:\d{2}:\d{2})\b/);

        const urlMatch =
            rawBlock.match(/\[url=([^\]]+)\]/i) ||
            rawBlock.match(/\[url\](https?:\/\/[^\[]+)\[\/url\]/i);

        const placeUrl = urlMatch ? decodeHtml(urlMatch[1]) : '';
        const targetId = extractTargetIdFromUrl(placeUrl);

              const cmd = createPlannerCommand({
            index,
            type: detectType(label),
            label,
            sendDate: dateMatch ? dateMatch[1] : '',
            sendTimeFrom: timeRangeMatch ? timeRangeMatch[1] : '',
            sendTimeTo: timeRangeMatch ? timeRangeMatch[2] : '',
            from,
            target,
            targetId,
            placeUrl,
            rawBlock
        });

        if (!cmd.target) cmd.parseWarnings.push('NO_TARGET_COORD');
        if (!cmd.from) cmd.parseWarnings.push('NO_SOURCE_COORD');
        if (!cmd.sendDate) cmd.parseWarnings.push('NO_SEND_DATE');
        if (!cmd.sendTimeFrom) cmd.parseWarnings.push('NO_SEND_TIME_FROM');
        if (!cmd.targetId) cmd.parseWarnings.push('NO_TARGET_ID');
        if (cmd.type === 'unknown') cmd.parseWarnings.push('UNKNOWN_TYPE');

        commands.push(cmd);
    }

    return uniqueBy(commands, c => [
        c.index,
        c.type,
        c.from,
        c.target,
        c.sendDate,
        c.sendTimeFrom
    ].join('|'));
}

