function toDateSafeValue(value) {
    if (!value) return null;
    const d = value instanceof Date ? value : new Date(value);
    return Number.isNaN(d.getTime()) ? null : d;
}

function isTargetOnlyVerifyExpired(timing) {
    const latest = toDateSafeValue(timing?.latest);
    if (!latest) return false;

    const graceMinutes = Number(Storage.get('verify.targetConfidenceMinutes', 90) || 90);
    const cutoff = latest.getTime() + graceMinutes * 60 * 1000;

    return Date.now() > cutoff;
}

function getTargetOnlyVerifyCutoff(timing) {
    const latest = toDateSafeValue(timing?.latest);
    if (!latest) return null;

    const graceMinutes = Number(Storage.get('verify.targetConfidenceMinutes', 90) || 90);
    return new Date(latest.getTime() + graceMinutes * 60 * 1000);
}

function toEpochMs(date, time) {
    if (!date || !time) return null;
    const dt = new Date(`${date}T${time}`);
    return Number.isNaN(dt.getTime()) ? null : dt.getTime();
}

function getPlannedSendWindowMs(order) {
    const startMs = toEpochMs(order?.sendDate || '', order?.sendTimeFrom || '');
    const endMs = toEpochMs(order?.sendDate || '', order?.sendTimeTo || order?.sendTimeFrom || '');

    if (!startMs || !endMs) {
        return { startMs: null, endMs: null, exact: false };
    }

    const exact = startMs === endMs;

    if (exact) {
        return {
            startMs: startMs - 60 * 1000,
            endMs: endMs + 60 * 1000,
            exact: true
        };
    }

    return {
        startMs,
        endMs,
        exact: false
    };
}

function computeActualSendMs(order, incomingRow) {
    const arrivalEpoch = Number(incomingRow?.arrivalEpoch || 0);
    const travelSeconds = Number(order?.timeSeconds || 0);

    if (!arrivalEpoch || !travelSeconds) return null;

    return arrivalEpoch - travelSeconds * 1000;
}

function doesIncomingMatchPlannedOrder(order, incomingRow) {
    if (!order || !incomingRow) return false;
    if (!incomingRow.arrivalEpoch) return false;

    const planned = getPlannedSendWindowMs(order);
    if (!planned.startMs || !planned.endMs) return false;

    const actualSendMs = computeActualSendMs(order, incomingRow);
    if (!actualSendMs) return false;

    return actualSendMs >= planned.startMs && actualSendMs <= planned.endMs;
}

function matchPlannedOrdersToIncoming(plannedOrders, incomingRows) {
    const orders = Array.isArray(plannedOrders) ? [...plannedOrders] : [];
    const incomings = Array.isArray(incomingRows) ? [...incomingRows] : [];

    orders.sort((a, b) => {
        const aMs = toEpochMs(a?.sendDate || '', a?.sendTimeFrom || '') || 0;
        const bMs = toEpochMs(b?.sendDate || '', b?.sendTimeFrom || '') || 0;
        return aMs - bMs;
    });

    incomings.sort((a, b) => {
        const aMs = Number(a?.arrivalEpoch || 0);
        const bMs = Number(b?.arrivalEpoch || 0);
        return aMs - bMs;
    });

    const usedIncoming = new Set();
    const matches = [];
    const missing = [];

    for (const order of orders) {
        let matchedIndex = -1;

        for (let i = 0; i < incomings.length; i++) {
            if (usedIncoming.has(i)) continue;

            const incomingRow = incomings[i];
            if (!doesIncomingMatchPlannedOrder(order, incomingRow)) continue;

            matchedIndex = i;
            break;
        }

        if (matchedIndex >= 0) {
            usedIncoming.add(matchedIndex);
            matches.push({
                order,
                incoming: incomings[matchedIndex],
                actualSendMs: computeActualSendMs(order, incomings[matchedIndex])
            });
        } else {
            missing.push(order);
        }
    }

    return {
        matchedCount: matches.length,
        missingCount: missing.length,
        matches,
        missing,
        unusedIncoming: incomings.filter((_, idx) => !usedIncoming.has(idx))
    };
}


