  function parseSummary(text) {
    const players = new Map();
    const targets = [];

    const lines = String(text || '')
        .replace(/\r/g, '')
        .split('\n')
        .map(x => x.trim())
        .filter(Boolean);

    for (const line of lines) {
        // łapiemy tylko linie zaczynające się od koordów celu
        const targetMatch = line.match(/^(\d{3}\|\d{3})\s*-/);
        if (!targetMatch) continue;

        const target = targetMatch[1];

        // bierzemy OSTATNI nawias w linii, bo tam siedzą gracze
        const groups = [...line.matchAll(/\(([^()]+)\)/g)];
        if (!groups.length) continue;

        const group = groups[groups.length - 1][1];
        const parts = group.split(',').map(x => x.trim()).filter(Boolean);

        const assignments = [];
              for (const part of parts) {
            const m = part.match(/^(.+?)\s+(\d+)\s*([osfb])$/i);
            if (!m) continue;

            const player = normalizeNick(m[1]);
            const count = Number(m[2] || 0);
            const type = String(m[3] || '').toLowerCase();

            if (!player || !count) continue;

            assignments.push({ player, count, type });

            if (!players.has(player)) {
                players.set(player, {
                    nick: player,
                    off: 0,
                    snob: 0,
                    fake: 0,
                    burzak: 0,
                    total: 0
                });
            }

            const row = players.get(player);

            if (type === 'o') row.off += count;
            if (type === 's') row.snob += count;
            if (type === 'f') row.fake += count;
            if (type === 'b') row.burzak += count;

            row.total += count;
        }

              if (assignments.length) {
            targets.push({
                target,
                assignments
            });
        }
    }

    return { players, targets };
}

