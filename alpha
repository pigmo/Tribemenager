            .filter(Boolean)
            .forEach(line => {
                const parts = line.split('=');
                if (parts.length < 2) return;

                const name = parts[0].trim();
                const id = parts.slice(1).join('=').trim();

                if (!name || !id) return;
                parsedTribes[name] = id;
            });

        if (!next.tribesByWorld || typeof next.tribesByWorld !== 'object') {
            next.tribesByWorld = {};
        }

        next.tribesByWorld[getCurrentWorld()] = parsedTribes;

