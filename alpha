function normalizeMailTemplateRow(row) {
    if (!row || typeof row !== 'object') return null;

    const id = String(row.id || '').trim();
    const name = String(row.name || '').trim();
    const subject = String(row.subject || '');
    const text = String(row.text || '');

    if (!id || !name) return null;

    return { id, name, subject, text };
}

function getMailTemplates() {
    const stored = Storage.get('mail.templates', null);

    if (!Array.isArray(stored) || !stored.length) {
        return getDefaultMailTemplates();
    }

    const normalized = stored
        .map(normalizeMailTemplateRow)
        .filter(Boolean);

    return normalized.length ? normalized : getDefaultMailTemplates();
}

function saveMailTemplates(templates) {
    const normalized = (Array.isArray(templates) ? templates : [])
        .map(normalizeMailTemplateRow)
        .filter(Boolean);

    Storage.set('mail.templates', normalized);
}

function getMailTemplateById(templateId) {
    const id = String(templateId || '').trim();
    if (!id) return null;

    return getMailTemplates().find(t => t.id === id) || null;
}

function buildMailTemplateId() {
    return `mail_tpl_${Date.now()}_${Math.random().toString(36).slice(2, 8)}`;
}

function upsertMailTemplate(template) {
    const row = normalizeMailTemplateRow(template);
    if (!row) return false;

    const templates = getMailTemplates();
    const idx = templates.findIndex(t => t.id === row.id);

    if (idx >= 0) {
        templates[idx] = row;
    } else {
        templates.push(row);
    }

    templates.sort((a, b) => a.name.localeCompare(b.name, 'pl'));
    saveMailTemplates(templates);
    return true;
}

function deleteMailTemplateById(templateId) {
    const id = String(templateId || '').trim();
    if (!id) return false;

    const templates = getMailTemplates();
    const next = templates.filter(t => t.id !== id);

    if (next.length === templates.length) {
        return false;
    }

    saveMailTemplates(next);
    return true;
}



function getMailCsrfTokenSafe() {
    const direct =
        window.csrf_token ||
        window.game_data?.csrf ||
        window.TribalWars?.game_data?.csrf ||
        '';

    if (direct) return direct;

    const html = document.documentElement?.innerHTML || '';

    const m1 = html.match(/var\s+csrf_token\s*=\s*'([^']+)'/);
    if (m1) return m1[1];

    const m2 = html.match(/"csrf":"([a-z0-9]+)"/i);
    if (m2) return m2[1];

    const mailForm = document.querySelector('form[action*="screen=mail"][action*="h="]');
    if (mailForm) {
        const action = decodeHtml(mailForm.getAttribute('action') || '');
        const m3 = action.match(/[?&]h=([a-z0-9]+)/i);
        if (m3) return m3[1];
    }

    return '';
}

function getCurrentVillageIdSafe() {
    const direct = window.game_data?.village?.id || '';
    if (direct) return String(direct);

    const html = document.documentElement?.innerHTML || '';

    const m1 = html.match(/"village":\{"id":(\d+)/);
    if (m1) return m1[1];

    const link = document.querySelector('a[href*="village="], form[action*="village="]');
    if (link) {
        const raw = decodeHtml(link.getAttribute('href') || link.getAttribute('action') || '');
        const m2 = raw.match(/[?&]village=(\d+)/);
        if (m2) return m2[1];
    }

    return '';
}

function getMailSendUrl() {
    const villageId = getCurrentVillageIdSafe();
    const csrf = getMailCsrfTokenSafe();

    if (!villageId || !csrf) {
        throw new Error(`Brak village ID albo csrf_token. village=${villageId || '-'} csrf=${csrf ? 'OK' : '-'}`);
    }

    return `/game.php?village=${villageId}&screen=mail&mode=new&action=send&h=${csrf}`;
}

async function sendTribalMail(toList, subject, text) {
    const url = getMailSendUrl();

    const body = new URLSearchParams();
    body.set('to', toList.join(';'));
    body.set('subject', subject);
    body.set('text', text);
    body.set('extended', '0');
    body.set('send', 'Wyślij');

    const res = await fetch(url, {
        method: 'POST',
        credentials: 'same-origin',
        headers: {
            'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8'
        },
        body: body.toString()
    });

    const html = await res.text();
    const doc = parseHtml(html);

    const pageText = (doc.body?.textContent || html || '')
        .replace(/\s+/g, ' ')
        .trim();

    const blockedButSent =
        /zablokowa/i.test(pageText) &&
        /wiadomość została wysłana do wszystkich odbiorców/i.test(pageText);

    const explicitErrorPatterns = [
        /maksymalnie/i,
        /za dużo/i,
        /nie znaleziono/i,
        /musisz podać/i,
        /wpisz temat/i,
        /wpisz treść/i,
        /nieprawidłow/i,
        /nie można wysłać/i,
        /błąd/i
    ];

    const explicitSuccessPatterns = [
        /wiadomość została wysłana/i,
        /została wysłana do wszystkich odbiorców/i
    ];

    const hasExplicitError = explicitErrorPatterns.some(rx => rx.test(pageText));
    const hasExplicitSuccess = explicitSuccessPatterns.some(rx => rx.test(pageText));

    const errorBox =
        doc.querySelector('.error') ||
        doc.querySelector('.error_box') ||
        doc.querySelector('.box-error') ||
        null;

    const successBox =
        doc.querySelector('.info') ||
        doc.querySelector('.info_box') ||
        doc.querySelector('.box-info') ||
        null;

    const looksLikeMailPage =
        /screen=mail/i.test(res.url || '') ||
        !!doc.querySelector("a[href*='screen=mail']") ||
        !!doc.querySelector("form[action*='screen=mail']");

    let ok = false;
    let partial = false;
    let message = '';

    if (blockedButSent) {
        ok = true;
        partial = true;
        message = 'Jeden z odbiorców Cię zablokował, ale wiadomość została wysłana do pozostałych.';
    } else if (hasExplicitError || errorBox) {
        ok = false;
        message = (errorBox?.textContent || pageText || `HTTP ${res.status}`)
            .replace(/\s+/g, ' ')
            .trim()
            .slice(0, 220);
    } else if (hasExplicitSuccess || successBox) {
        ok = true;
    } else if (res.ok && looksLikeMailPage) {
        // fallback jak w stable: brak twardego błędu + 200 + sensowna strona maila = sukces
        ok = true;
    } else {
        ok = false;
        message = `HTTP ${res.status}`;
    }

    return {
        ok,
        partial,
        status: res.status,
        message,
        html
    };
}


function wrapTextareaSelection(textarea, openTag, closeTag, placeholder = '') {
    const start = textarea.selectionStart ?? 0;
    const end = textarea.selectionEnd ?? 0;
    const value = textarea.value || '';

    const selected = value.slice(start, end);
    const insertText = selected
        ? `${openTag}${selected}${closeTag}`
        : `${openTag}${placeholder}${closeTag}`;

    textarea.value = value.slice(0, start) + insertText + value.slice(end);

    const cursorStart = start + openTag.length;
    const cursorEnd = cursorStart + (selected ? selected.length : placeholder.length);

    textarea.focus();
    textarea.setSelectionRange(cursorStart, cursorEnd);
}

function insertIntoTextarea(textarea, text) {
    const start = textarea.selectionStart ?? 0;
    const end = textarea.selectionEnd ?? 0;
    const value = textarea.value || '';

    textarea.value = value.slice(0, start) + text + value.slice(end);

    const pos = start + text.length;
    textarea.focus();
    textarea.setSelectionRange(pos, pos);
}

