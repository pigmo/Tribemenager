   async function fetchRankingData(box, neededPlayers) {
        const cached = getStoredJson(STORAGE_KEYS.rankingCache, {});
        const neededList = [...neededPlayers];
        const missingFromCache = neededList.filter(nick => !cached[nick]);

        if (isCacheValid(STORAGE_KEYS.rankingCacheTime) && missingFromCache.length === 0) {
            log('📦 Ranking cache hit:', Object.keys(cached).length);
            return cached;
        }

        const rankingData = { ...cached };
        const found = new Set(Object.keys(rankingData).filter(n => neededPlayers.has(n)));

        let pageIndex = 0;
        let offset = 0;
        const safetyLimit = 200;


        while (pageIndex < safetyLimit) {
            pageIndex++;

            const foundCount = found.size;
            const neededCount = neededPlayers.size;
            const percent = neededCount ? (foundCount / neededCount) * 100 : 100;

            log('📊 Ranking page:', pageIndex, 'offset:', offset, 'found:', `${foundCount}/${neededCount}`);

            updateProgress(
                box,
                Math.min(95, percent),
                'Pobieranie rankingu...',
                `Znaleziono ${foundCount}/${neededCount} potrzebnych graczy`
            );

            if (foundCount >= neededCount) {
                log('✅ Mam wszystkich potrzebnych graczy, stop.');
                break;
            }

            const page = await fetchRankingPage(offset);

            if (!page.rows) {
                log('🛑 Ranking auto-stop: pusta strona.');
                break;
            }

            for (const [nick, stats] of Object.entries(page.data)) {
                rankingData[nick] = stats;
                if (neededPlayers.has(nick)) {
                    found.add(nick);
                }
            }

            if (found.size >= neededPlayers.size) {
                log('✅ Po tej stronie znaleziono komplet graczy.');
                break;
            }

            if (page.rows < 25) {
                log('🛑 Ostatnia niepełna strona rankingu.');
                break;
            }

            offset += 25;
            await sleep(RANKING_DELAY);
        }

        setStoredJson(STORAGE_KEYS.rankingCache, rankingData);
        localStorage.setItem(STORAGE_KEYS.rankingCacheTime, String(getNow()));

        const stillMissing = [...neededPlayers].filter(nick => !rankingData[nick]);
        if (stillMissing.length) {
            log('⚠️ Brak w rankingu:', stillMissing);
        }

        return rankingData;
    }

