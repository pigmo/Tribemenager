   function buildBBCode(sorted, total, playerStats, inactiveByTribe, periodStats) {
    const config = getConfig();
     const topCount = Number(config.table?.style?.topCount || 10);

const topSuffix = String(config.table?.style?.topTitle || 'największych sadystów').trim();

const topTitle = `🔥 TOP ${topCount} ${topSuffix} 🔥`;

const restTitle = String(config.table?.style?.restTitle || '📊 RESZTA PLEMIENIA');
const inactiveTitle = String(config.table?.style?.inactiveTitle || 'BRAK AKTYWNOŚCI');



    const showTop = !!config.table?.sections?.showTop;
    const showRest = !!config.table?.sections?.showRest;
    const showInactive = !!config.table?.sections?.showInactive;
    const showSummary = !!config.table?.sections?.showSummary;

    const podiumMode = config.table?.style?.podiumMode || 'medals';
    const topMode = config.table?.style?.topMode || 'fire';
    const restMode = config.table?.style?.restMode || 'stars';
    const inactiveMode = config.table?.style?.inactiveMode || 'skull';

    const highThreshold = Number(config.table?.thresholds?.high ?? 2.0);
    const mediumThreshold = Number(config.table?.thresholds?.medium ?? 0.8);
    const columns = config.table?.columns || {};

    let bb = '';

    let highCount = 0;
    let lowCount = 0;

    sorted.forEach(([_, val]) => {
        const p = total ? (val / total) * 100 : 0;
        if (p >= 4) highCount++;
        if (p < 0.8) lowCount++;
    });

    if (periodStats?.firstDate && periodStats?.lastDate) {
        bb += `[b]📅 Okres:[/b] ${formatDateTimePL(periodStats.firstDate)} → ${formatDateTimePL(periodStats.lastDate)}\n`;
        bb += `[b]📦 Łącznie wysłano:[/b] ${total}\n`;
        bb += `[b]📉 Średnia / dzień:[/b] ${periodStats.averagePerDay.toFixed(2)}\n\n`;
    }

    if (showTop) {
        bb += `[b]${topTitle}[/b]\n`;
        bb += '[table]\n';
        bb += buildTableHeader(columns);

        sorted.slice(0, topCount).forEach(([nick, val], i) => {
            const s = playerStats[nick] || { points: 0, villages: 0 };
            const percent = total ? ((val / total) * 100).toFixed(2) + '%' : '0.00%';
            const pv = s.villages ? (val / s.villages).toFixed(2) : '-';
            const pp = s.points ? (val / (s.points / 1000)).toFixed(2) : '-';

            const rank = i + 1;
            const icon = rank <= 3
                ? getSingleIcon(podiumMode, rank)
                : getSingleIcon(topMode, rank);

            const prefix = icon ? `${icon} ` : '';

            bb += buildTableRow(columns, {
                player: `[b]${prefix}[player]${nick}[/player][/b]`,
                fakeCount: `${val}`,
                percent: `${percent}`,
                perVillage: `${pv}`,
                per1kPoints: `${pp}`,
                points: `${s.points || 0}`,
                villages: `${s.villages || 0}`
            });
        });

        bb += '[/table]\n\n';
    }

    const days = periodStats?.dailyStats || [];
    if (days.length) {
        bb += `[b]🏅 MVP DZIENNE[/b]\n\n`;

        days.forEach(day => {
            const fake = day.mvp?.fakeCount;
            const pv = day.mvp?.perVillage;
            const pp = day.mvp?.per1kPoints;

            bb += `[spoiler=${formatDatePL(day.date)} | suma: ${day.total}]\n`;
            bb += `🔥 Najwięcej fejek: ${fake ? `[player]${fake.nick}[/player] (${fake.fakeCount})` : '-'}\n`;
            bb += `🏘 Najwięcej /wioskę: ${pv ? `[player]${pv.nick}[/player] (${pv.metricValue.toFixed(2)})` : '-'}\n`;
            bb += `📈 Najwięcej /1k pkt: ${pp ? `[player]${pp.nick}[/player] (${pp.metricValue.toFixed(2)})` : '-'}\n`;
            bb += `[/spoiler]\n\n`;
        });
    }

    if (showRest && sorted.length > topCount) {
        bb += `[b]${restTitle}[/b]\n`;
        bb += '[table]\n';
        bb += buildTableHeader(columns);

        sorted.slice(topCount).forEach(([nick, val]) => {
            const s = playerStats[nick] || { points: 0, villages: 0 };
            const percentValue = total ? (val / total) * 100 : 0;
            const percent = percentValue.toFixed(2) + '%';
            const pv = s.villages ? (val / s.villages).toFixed(2) : '-';
            const pp = s.points ? (val / (s.points / 1000)).toFixed(2) : '-';

            const tierIcons = getTieredIcons(percentValue, restMode, highThreshold, mediumThreshold);
            const prefix = tierIcons ? `${tierIcons} ` : '';

            bb += buildTableRow(columns, {
                player: `${prefix}[player]${nick}[/player]`,
                fakeCount: `${val}`,
                percent: `${percent}`,
                perVillage: `${pv}`,
                per1kPoints: `${pp}`,
                points: `${s.points || 0}`,
                villages: `${s.villages || 0}`
            });
        });

        bb += '[/table]\n\n';
    }

    if (showSummary) {
        bb += `[b]🚀 Powyżej 4%: ${highCount}[/b]\n`;
        bb += `[b]📉 Poniżej 0.8%: ${lowCount}[/b]\n\n`;
    }

    if (showInactive) {
        const inactiveIcon = getSingleIcon(inactiveMode);
        const inactivePrefix = inactiveIcon ? `${inactiveIcon} ` : '';

        bb += `[b]${inactivePrefix}${inactiveTitle}[/b]\n`;
        for (const [tribe, list] of Object.entries(inactiveByTribe)) {
            bb += `\n[spoiler=${tribe} (${list.length})]\n`;
            list.forEach(nick => {
                bb += `[player]${nick}[/player]\n`;
            });
            bb += `[/spoiler]\n`;
        }
    }

    return bb;
}

