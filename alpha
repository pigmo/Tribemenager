  function getSavedVerifyOperationsList() {
    const cache = loadOperationCache();

    return Object.entries(cache)
        .map(([name, entry]) => ({
            name: String(name || '').trim(),
            updatedAt: Number(entry?.updatedAt || 0),
            savedAt: String(entry?.savedAt || '').trim(),
