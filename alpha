    if (state.summaryMap instanceof Map) {
        for (const nick of state.summaryMap.keys()) {
            const clean = normalizeNick(nick);
            if (clean) names.add(clean);
        }
    }

    if (state.plannerByPlayer instanceof Map) {
        for (const nick of state.plannerByPlayer.keys()) {
            const clean = normalizeNick(nick);
            if (clean) names.add(clean);
        }
    }

    return [...names].sort((a, b) => a.localeCompare(b, 'pl'));
}

  function normalizeSharingType(type) {
    const raw = String(type || '').trim().toLowerCase();

    if (raw === 'o' || raw === 'off') return 'o';
    if (raw === 'b' || raw === 'burzak') return 'b';
    if (raw === 's' || raw === 'snob' || raw === 'szlachta') return 's';

    return '';
}

function isSharingRelevantType(type) {
    return !!normalizeSharingType(type);
}

function getSharingRoleLabel(type) {
    const normalized = normalizeSharingType(type);

    if (normalized === 'o') return 'OFF';
    if (normalized === 'b') return 'BURZAK';
    if (normalized === 's') return 'SZLACHTA';

    return 'INNE';
}

function formatSharingRoles(roles) {
    return (Array.isArray(roles) ? roles : [])
        .filter(role => role && role.type && Number(role.count || 0) > 0)
        .map(role => `${getSharingRoleLabel(role.type)} x${Number(role.count || 0)}`)
        .join(', ');
}

function aggregateSharingParticipants(assignments) {
    const byPlayer = new Map();

    for (const raw of (assignments || [])) {
        const player = normalizeNick(raw?.player || '');
        const type = normalizeSharingType(raw?.type || '');
        const count = Number(raw?.count || 0);

        if (!player || !type || count <= 0) continue;

        if (!byPlayer.has(player)) {
            byPlayer.set(player, {
                player,
                totalCount: 0,
                rolesMap: new Map(),
            });
        }

        const row = byPlayer.get(player);

        row.totalCount += count;
        row.rolesMap.set(type, (row.rolesMap.get(type) || 0) + count);
    }

    return [...byPlayer.values()]
        .map(row => ({
            player: row.player,
            totalCount: row.totalCount,
            roles: [...row.rolesMap.entries()]
                .map(([type, count]) => ({
                    type,
                    count,
                }))
                .sort((a, b) => getSharingRoleLabel(a.type).localeCompare(getSharingRoleLabel(b.type), 'pl')),
        }))
        .sort((a, b) => a.player.localeCompare(b.player, 'pl'));
}

 function formatPlayerBbTag(player) {
    const nick = String(player || '').trim();
    if (!nick) return '';
    return `[player]${nick}[/player]`;
}


function buildSharingBaseByPlayer(targets) {
    const byPlayer = new Map();

    for (const targetRow of (targets || [])) {
        const target = normalizeCoord(targetRow?.target || '');
        if (!target) continue;

        const participants = aggregateSharingParticipants(targetRow?.assignments || [])
            .filter(row => row.player && row.roles.length && row.totalCount > 0);

        if (!participants.length) continue;

        for (const current of participants) {
            if (!byPlayer.has(current.player)) {
                byPlayer.set(current.player, {
                    player: current.player,
                    items: [],
                    totalTargets: 0,
                    totalNeedPlayers: 0,
                    totalNeedCommands: 0,
                });
            }

            const ownerRow = byPlayer.get(current.player);

            ownerRow.items.push({
                target,
                selfRoles: current.roles.map(role => ({
                    type: role.type,
                    count: role.count,
                })),
                selfCount: current.totalCount,
                needFrom: participants
                    .filter(other => other.player !== current.player)
                    .map(other => ({
                        player: other.player,
                        totalCount: other.totalCount,
                        roles: other.roles.map(role => ({
                            type: role.type,
                            count: role.count,
                        })),
                    }))
                    .sort((a, b) => a.player.localeCompare(b.player, 'pl')),
            });
        }
    }

    for (const row of byPlayer.values()) {
        row.items = row.items
            .filter(item => Array.isArray(item.needFrom) && item.needFrom.length > 0)
            .sort((a, b) => a.target.localeCompare(b.target, 'pl'));

        row.totalTargets = row.items.length;
        row.totalNeedPlayers = row.items.reduce((sum, item) => sum + item.needFrom.length, 0);
        row.totalNeedCommands = row.items.reduce(
            (sum, item) => sum + item.needFrom.reduce((inner, other) => inner + Number(other.totalCount || 0), 0),
            0
        );
    }

    return new Map(
        [...byPlayer.entries()]
            .filter(([, row]) => Array.isArray(row.items) && row.items.length > 0)
            .sort((a, b) => a[0].localeCompare(b[0], 'pl'))
    );
}
  function aggregateSharingNeedsForMessage(baseRow) {
    const bySender = new Map();
    const items = Array.isArray(baseRow?.items) ? baseRow.items : [];

    for (const item of items) {
        const target = normalizeCoord(item?.target || '');
        if (!target) continue;

        for (const other of (item.needFrom || [])) {
            const sender = normalizeNick(other?.player || '');
            if (!sender) continue;

            if (!bySender.has(sender)) {
                bySender.set(sender, {
                    player: sender,
                    totalCount: 0,
                    rolesMap: new Map(),
                    targetsSet: new Set(),
                });
            }

            const row = bySender.get(sender);

            row.totalCount += Number(other?.totalCount || 0);
            row.targetsSet.add(target);

            for (const role of (other.roles || [])) {
                const type = normalizeSharingType(role?.type || '');
                const count = Number(role?.count || 0);
                if (!type || count <= 0) continue;

                row.rolesMap.set(type, (row.rolesMap.get(type) || 0) + count);
            }
        }
    }

    return [...bySender.values()]
        .map(row => ({
            player: row.player,
            totalCount: row.totalCount,
            roles: [...row.rolesMap.entries()]
                .map(([type, count]) => ({ type, count }))
                .sort((a, b) => getSharingRoleLabel(a.type).localeCompare(getSharingRoleLabel(b.type), 'pl')),
            targets: [...row.targetsSet].sort((a, b) => a.localeCompare(b, 'pl')),
        }))
        .sort((a, b) => a.player.localeCompare(b.player, 'pl'));
}

function buildSharingMessageForPlayer(player, baseRow, operationName) {
    const grouped = aggregateSharingNeedsForMessage(baseRow);
    if (!grouped.length) return '';

    const lines = [];

    if (operationName) {
        lines.push(`Na operację ${operationName} potrzebujesz komend od tych graczy:`);
    } else {
        lines.push('Potrzebujesz komend od tych graczy:');
    }

    lines.push('');

    for (const row of grouped) {
        const commandsLabel = row.totalCount === 1 ? 'komenda' : (row.totalCount >= 2 && row.totalCount <= 4 ? 'komendy' : 'komend');
        const rolesText = formatSharingRoles(row.roles);
        const targetsText = row.targets.join(', ');

        lines.push(`${formatPlayerBbTag(row.player)} — ${row.totalCount} ${commandsLabel}${rolesText ? ` (${rolesText})` : ''}`);
        lines.push(`Cele: ${targetsText}`);
        lines.push('');
    }

    lines.push('Komendy dla Rady zostają zawsze.');

    return lines.join('\n').trim();
}

function buildSharingMessagesByPlayer(baseMap, operationName, trustedPlayers) {
    const result = new Map();
    const trustedSet = new Set(normalizePlayersArray(trustedPlayers));

    if (!(baseMap instanceof Map)) return result;

    if (!trustedSet.size) {
        return result;
    }

    for (const [player, row] of baseMap.entries()) {
        if (!trustedSet.has(player)) continue;

        const body = buildSharingMessageForPlayer(player, row, operationName);
        if (!body) continue;

        result.set(player, {
            player,
            subject: operationName ? `Sharing komend - ${operationName}` : 'Sharing komend',
            body,
        });
    }

    return result;
}

