  function findApiArrayCandidates(root, basePath = '', out = []) {
    if (root === null || root === undefined) return out;

    if (Array.isArray(root)) {
        if (root.length && typeof root[0] === 'object' && root[0] !== null) {
            const keys = Object.keys(root[0]);
            const joined = keys.join('|').toLowerCase();

            const score =
                (/(player|nick|name)/.test(joined) ? 2 : 0) +
                (/(target|coord|village)/.test(joined) ? 2 : 0) +
                (/(send|arrival|enter|time|date)/.test(joined) ? 2 : 0) +
                (/(type|command|noble|ram|catapult|fake|off)/.test(joined) ? 2 : 0);

            out.push({
                path: basePath || 'root',
                length: root.length,
                keys,
                score
            });
        }


              root.forEach((item, idx) => {
            if (idx > 2) return;
            findApiArrayCandidates(item, `${basePath}[${idx}]`, out);
        });

        return out;
    }

    if (typeof root === 'object') {
        Object.entries(root).forEach(([key, value]) => {
            const path = basePath ? `${basePath}.${key}` : key;
            findApiArrayCandidates(value, path, out);
        });
    }

    return out;
}

function parsePlannerFromApi(data, player, plannerUrl, apiUrl) {
    const parseMeta = {
        strategy: 'api-overview',
        warnings: []
    };

    const rootKeys = data && typeof data === 'object' ? Object.keys(data) : [];
    const outlineKeys =
        data?.outline && typeof data.outline === 'object'
            ? Object.keys(data.outline)
            : [];
    const worldKeys =
        data?.world && typeof data.world === 'object'
            ? Object.keys(data.world)
            : [];

    const targetsLength = Array.isArray(data?.targets) ? data.targets.length : 0;

    const firstTargetKeys =
        Array.isArray(data?.targets) &&
        data.targets.length &&
        typeof data.targets[0] === 'object'
            ? Object.keys(data.targets[0])
            : [];

    const candidateArrays = findApiArrayCandidates(data)
        .sort((a, b) => b.score - a.score || b.length - a.length)
        .slice(0, 12);

    const commands = parsePlannerCommandsFromApi(data, player);

    parseMeta.apiRootKeys = rootKeys;
    parseMeta.apiOutlineKeys = outlineKeys;
    parseMeta.apiWorldKeys = worldKeys;
    parseMeta.apiTargetsLength = targetsLength;
    parseMeta.apiFirstTargetKeys = firstTargetKeys;
    parseMeta.apiCandidateArrays = candidateArrays;
    parseMeta.apiCommandsCount = commands.length;

    if (!commands.length) {
        parseMeta.warnings.push('API nie zwróciło żadnych komend w targets[].my_orders[]');
    }

    return {
        player,
        plannerUrl,
        plannerApiUrl: apiUrl,
        outlineText: '',
        commands,
        plannerPlayerName: normalizeNick(player),
        apiRaw: data,
        parseMeta
    };
}

  function parsePlannerDocument(doc, player, plannerUrl) {
    const parseMeta = {
        strategy: '',
        warnings: []
    };

    const textareas = findPlannerTextareas(doc);

    if (textareas.length) {
        let best = textareas[0];
        let bestCommands = parsePlannerOutline(best.text);

        for (const item of textareas.slice(1)) {
            const cmds = parsePlannerOutline(item.text);
            if (cmds.length > bestCommands.length) {
                best = item;
                bestCommands = cmds;
            }
        }

        if (bestCommands.length) {
            parseMeta.strategy = 'textarea-outline';
            return {
                player,
                plannerUrl,
                outlineText: best.text,
                commands: bestCommands,
                plannerPlayerName: normalizeNick(doc.querySelector('h1.font-nav, h1')?.textContent || ''),
                parseMeta
            };
        }

        parseMeta.warnings.push('TEXTAREA_FOUND_BUT_NO_COMMANDS_PARSED');
    }

    const htmlCommands = parsePlannerCommandsFromHtml(doc);
    if (htmlCommands.length) {
        parseMeta.strategy = 'html-fallback';
        parseMeta.warnings.push('FALLBACK_HTML_PARSER_USED');

        return {
            player,
            plannerUrl,
            outlineText: '',
            commands: htmlCommands,
            plannerPlayerName: normalizeNick(doc.querySelector('h1.font-nav, h1')?.textContent || ''),
            parseMeta
        };
    }

    parseMeta.strategy = 'none';
    parseMeta.warnings.push('NO_COMMANDS_FOUND');

    return {
        player,
        plannerUrl,
        outlineText: '',
        commands: [],
        plannerPlayerName: normalizeNick(doc.querySelector('h1.font-nav, h1')?.textContent || ''),
        parseMeta
