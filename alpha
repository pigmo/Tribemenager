async function fetchTribeMembersForMail(tribeId, tribeName = '') {
    const html = await sameOriginFetchText(
        `/game.php?screen=info_ally&id=${tribeId}`,
        {},
        `Mail -> człon ${tribeName || tribeId}`
    );

    const doc = parseHtml(html);
    const members = new Set();

    for (const row of doc.querySelectorAll('table.vis tr')) {
        const cells = row.querySelectorAll('td');
        if (cells.length < 4) continue;

        const link = row.querySelector("a[href*='screen=info_player&id=']");
        if (!link) continue;

        const nick = normalizeNick(link.textContent);
        if (!nick) continue;

        const points = cells[2]?.textContent?.trim();
        const villages = cells[4]?.textContent?.trim();

        if (!points || !villages) continue;

        members.add(nick);
    }

    return [...members];
}

async function loadMailTribeData(appendLog) {
    const tribes = getTribes();

    if (!Object.keys(tribes).length) {
        appendLog('Brak skonfigurowanych członów w Fejkach. Możesz nadal wysyłać do ręcznych odbiorców.', '#ffcc66');
        return {};
    }

    const cached = getStoredJson(STORAGE_KEYS.tribeCache, {});
    const valid = isCacheValid(STORAGE_KEYS.tribeCacheTime) &&
                  isTribeCacheCompatible(cached, tribes);

    if (valid) {
        appendLog(`📦 Wczytano listy graczy z cache (${Object.keys(cached).length} członów).`, '#8f8');
        return cached;
    }

    const out = {};
    const entries = Object.entries(tribes);

    for (let i = 0; i < entries.length; i++) {
        const [name, id] = entries[i];
        appendLog(`🏰 Pobieram ${name} (${i + 1}/${entries.length})...`, '#9cf');
        out[name] = await fetchTribeMembersForMail(id, name);
        appendLog(`✅ ${name}: ${out[name].length} graczy`, '#8f8');
    }

    setStoredJson(STORAGE_KEYS.tribeCache, out);
    localStorage.setItem(STORAGE_KEYS.tribeCacheTime, String(getNow()));

    return out;
}

