  function getObjectPaths(obj, prefix = '', out = []) {
    if (obj === null || obj === undefined) return out;

    if (Array.isArray(obj)) {
        out.push(`${prefix}[]`);
        if (obj.length) {
            getObjectPaths(obj[0], `${prefix}[0]`, out);
        }
        return out;
    }

    if (typeof obj === 'object') {
        Object.keys(obj).forEach(key => {
            const path = prefix ? `${prefix}.${key}` : key;
            out.push(path);
            getObjectPaths(obj[key], path, out);
        });
    }

    return out;
}

