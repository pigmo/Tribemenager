  function parseForumPostDate(rawHeaderText) {
    const text = String(rawHeaderText || '')
        .replace(/\u00a0/g, ' ')
        .replace(/\s+/g, ' ')
        .trim();

    if (!text) return null;

    const now = new Date();

    let match = text.match(/dnia\s+(\d{1,2})\.(\d{1,2})\.(\d{4})\s+o\s+(\d{1,2}):(\d{2})/i);
    if (match) {
        const [, dd, mm, yyyy, hh, min] = match;
        return new Date(
            Number(yyyy),
            Number(mm) - 1,
            Number(dd),
            Number(hh),
            Number(min),
            0,
            0
        );
    }

    match = text.match(/dnia\s+(\d{1,2})\.(\d{1,2})\.\s+o\s+(\d{1,2}):(\d{2})/i);
    if (match) {
        const [, dd, mm, hh, min] = match;
        return new Date(
            now.getFullYear(),
            Number(mm) - 1,
            Number(dd),
            Number(hh),
            Number(min),
            0,
            0
        );
    }

    match = text.match(/wczoraj\s+o\s+(\d{1,2}):(\d{2})/i);
    if (match) {
        const [, hh, min] = match;
        const d = new Date(now);
        d.setDate(d.getDate() - 1);
        d.setHours(Number(hh), Number(min), 0, 0);
        return d;
    }

    match = text.match(/dzisiaj\s+o\s+(\d{1,2}):(\d{2})/i);
    if (match) {
        const [, hh, min] = match;
        const d = new Date(now);
        d.setHours(Number(hh), Number(min), 0, 0);
        return d;
    }

    return null;
}

